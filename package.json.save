xxX{
  "name": "attendance-calculator",
  "version": "1.0.0",
  "description": "Smart Attendance Calculator for Matrusri Engineering College",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix server run build && npm --prefix client run build",
    "install-all": "npm install && npm --prefix server install && npm --prefix client install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["attendance", "calculator", "college"],
  "author": "Matrusri Engineering College"
}
