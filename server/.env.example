# MongoDB Connection String
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/attendance-db

# JWT Secret for Authentication
# Generate a strong random key (min 32 characters recommended)
JWT_SECRET=your-very-secure-random-secret-key-min-32-chars

# Server Port (Render will set this automatically, can be left as 5000)
PORT=5000

# Environment
NODE_ENV=production

# CORS Configuration (Allow requests from your Vercel frontend)
CORS_ORIGIN=https://your-vercel-frontend.vercel.app
